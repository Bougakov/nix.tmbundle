		<key>constants</key>
		<dict>
			<key>name</key>
			<string>constant.language.nix</string>
			<key>match</key>
			<string>(?&lt;![\w'.-])(true|false|null)(?![\w'-])</string>
		</dict>
		<key>uri</key>
		<dict>
			<key>name</key>
			<string>string.unquoted.url.nix</string>
			<key>match</key>
			<string>(?&lt;![\w'.-])[a-zA-Z][a-zA-Z0-9+.-]*:[a-zA-Z0-9%/?:@&amp;=+$,_.!~*'-]+</string>
		</dict>
		<key>search-path</key>
		<dict>
			<key>name</key>
			<string>string.unquoted.spath.nix</string>
			<key>match</key>
			<string>&lt;[a-zA-Z0-9._+-]+(/[a-zA-Z0-9._+-]+)*&gt;</string>
		</dict>
		<key>path</key>
		<dict>
			<key>name</key>
			<string>string.unquoted.path.nix</string>
			<key>match</key>
			<string>(?&lt;![\w'.+-])~?[a-zA-Z0-9._+-]*(/[a-zA-Z0-9._+-]+)+/?</string>
		</dict>
		<key>attribute-def</key>
		<dict>
			<key>name</key>
			<string>entity.other.attribute-name.nix</string>
			<key>match</key>
			<string>(?&lt;![\w'.-])[a-zA-Z_][a-zA-Z0-9_'-]*(\s*\.\s*([a-zA-Z_][a-zA-Z0-9_'-]*|\"[^\"]*\"|\$\{[^}]*\}))*(?=\s*=(?!=))</string>
		</dict>
		<key>builtins</key>
		<dict>
			<key>patterns</key>
			<array>
				<dict>
					<key>name</key>
					<string>support.function.builtin.nix</string>
					<key>match</key>
					<string>(?&lt;![\w'.-])builtins\s*\.\s*[a-zA-Z_][a-zA-Z0-9_']*</string>
				</dict>
				<dict>
					<key>name</key>
					<string>support.function.builtin.nix</string>
					<key>match</key>
					<string>(?&lt;![\w'.-])(abort|baseNameOf|builtins|derivation|dirOf|fetchGit|fetchMercurial|fetchTarball|fetchTree|fromTOML|import|isNull|map|placeholder|removeAttrs|scopedImport|throw|toString)(?![\w'-])</string>
				</dict>
			</array>
		</dict>
		<key>number</key>
		<dict>
			<key>patterns</key>
			<array>
				<dict>
					<key>name</key>
					<string>constant.numeric.float.nix</string>
					<key>match</key>
					<string>(?&lt;![\w.])(\d+\.\d*|\.\d+)([eE][+-]?\d+)?(?![\w.])</string>
				</dict>
				<dict>
					<key>name</key>
					<string>constant.numeric.integer.nix</string>
					<key>match</key>
					<string>(?&lt;![\w.])\d+(?![\w.])</string>
				</dict>
			</array>
		</dict>
		<key>function-param</key>
		<dict>
			<key>patterns</key>
			<array>
				<dict>
					<key>name</key>
					<string>variable.parameter.function.nix</string>
					<key>match</key>
					<string>(?&lt;![\w'.-])[a-zA-Z_][a-zA-Z0-9_'-]*(?=\s*[,?])</string>
				</dict>
				<dict>
					<key>name</key>
					<string>variable.parameter.function.nix</string>
					<key>match</key>
					<string>(?&lt;![\w'.-])[a-zA-Z_][a-zA-Z0-9_'-]*(?=\s*:(?![a-zA-Z0-9%/?:@&amp;=+$,_.!~*'-]))</string>
				</dict>
			</array>
		</dict>
		<key>operators</key>
		<dict>
			<key>patterns</key>
			<array>
				<dict>
					<key>name</key>
					<string>keyword.operator.word.nix</string>
					<key>match</key>
					<string>(?&lt;![\w'.-])or(?![\w'-])</string>
				</dict>
				<dict>
					<key>name</key>
					<string>keyword.operator.nix</string>
					<key>match</key>
					<string>-&gt;|\+\+|//|==|!=|&lt;=|&gt;=|&amp;&amp;|\|\||\.\.\.|[-!+*&lt;&gt;@?/]</string>
				</dict>
				<dict>
					<key>name</key>
					<string>keyword.operator.assignment.nix</string>
					<key>match</key>
					<string>=</string>
				</dict>
			</array>
		</dict>
		<key>punctuation</key>
		<dict>
			<key>patterns</key>
			<array>
				<dict>
					<key>name</key>
					<string>punctuation.terminator.statement.nix</string>
					<key>match</key>
					<string>;</string>
				</dict>
				<dict>
					<key>name</key>
					<string>punctuation.separator.comma.nix</string>
					<key>match</key>
					<string>,</string>
				</dict>
				<dict>
					<key>name</key>
					<string>punctuation.separator.colon.nix</string>
					<key>match</key>
					<string>:</string>
				</dict>
			</array>
		</dict>
