		<dict>
			<key>patterns</key>
			<array>
				<dict>
					<key>name</key>
					<string>keyword.control.nix</string>
					<key>match</key>
					<string>(?&lt;![\w'.-])(if|then|else|assert|with|let|in)(?![\w'-])</string>
				</dict>
				<dict>
					<key>name</key>
					<string>keyword.other.nix</string>
					<key>match</key>
					<string>(?&lt;![\w'.-])(rec|inherit)(?![\w'-])</string>
				</dict>
			</array>
